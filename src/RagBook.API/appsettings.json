{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Session": {
    "CookieName": "ragbook_session",
    "SlidingExpirationDays": 30,
    "Secure": true,
    "SameSite": "Strict"
  },
  "Quota": {
    "MaxDocuments": 10,
    "MaxFileSizeMb": 10,
    "MaxTotalMb": 50
  },
  "Folders": {
    "MaxDepth": 3,
    "MaxNameLength": 100
  },
  "FileStorage": {
    "RootPath": "../../.blobstore"
  }
}
