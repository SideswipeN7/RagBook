{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Session": {
    "CookieName": "ragbook_session",
    "SlidingExpirationDays": 30,
    "Secure": true,
    "SameSite": "Strict"
  },
  "Quota": {
    "MaxDocuments": 10,
    "MaxFileSizeMb": 10,
    "MaxTotalMb": 50
  },
  "Folders": {
    "MaxDepth": 3,
    "MaxNameLength": 100
  },
  "FileStorage": {
    "RootPath": "../../.blobstore"
  },
  "ApiKeyStore": {
    "Ttl": "30.00:00:00",
    "ThrottleMaxAttempts": 5,
    "ThrottleWindow": "00:01:00"
  },
  "Anthropic": {
    "BaseUrl": "https://api.anthropic.com",
    "AnthropicVersion": "2023-06-01",
    "GenerationModel": "claude-sonnet-5",
    "MaxOutputTokens": 1024
  },
  "Rag": {
    "TopK": 8,
    "SimilarityThreshold": 0.75,
    "MaxContextChars": 8000,
    "StreamHeartbeatSeconds": 15
  },
  "Chat": {
    "HistoryPairs": 6,
    "TitleMaxChars": 60
  },
  "Demo": {
    "MaxQuestionsPerSession": 10,
    "MaxQuestionsPerIpPerHour": 20,
    "SessionCounterTtlHours": 24,
    "Documents": [
      {
        "Id": "d3d00000-0000-4000-8000-0000000000a1",
        "FileName": "demo-umowa.txt",
        "ContentType": "text/plain",
        "Text": "Przykladowa umowa najmu (dokument demo). Okres wypowiedzenia wynosi trzy miesiace. Czynsz platny jest do dziesiatego dnia kazdego miesiaca. Kaucja wynosi rownowartosc jednomiesiecznego czynszu i podlega zwrotowi po zakonczeniu najmu."
      },
      {
        "Id": "d3d00000-0000-4000-8000-0000000000b2",
        "FileName": "demo-dokumentacja.txt",
        "ContentType": "text/plain",
        "Text": "Dokumentacja techniczna RagBook (dokument demo). System indeksuje dokumenty, dzieli je na fragmenty i wyszukuje semantycznie za pomoca pgvector. Odpowiedzi sa generowane wylacznie na podstawie znalezionych fragmentow i zawieraja cytaty do zrodel."
      }
    ]
  }
}
