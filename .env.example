# RagBook local run — copy to `.env` and fill the (optional) keys, then `docker compose up --build`.
# All secrets come from here locally and from Secret Manager in the cloud — never committed.

# --- Database (local defaults are fine) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ragbookdb
ConnectionStrings__ragbookdb=Host=postgres;Port=5432;Database=ragbookdb;Username=postgres;Password=postgres

# --- Secrets (optional for a basic run) ---
# Pays for demo-mode answers (US-03). Leave empty to browse the app; demo chat then shows "demo temporarily
# unavailable" instead of generating. Set an Anthropic key to enable keyless demo answers.
Anthropic__ApplicationKey=
# Embedding provider key (Voyage). Leave empty to use the deterministic stand-in embedding (good enough to run the
# whole pipeline locally); set it for real semantic search.
Embedding__ApiKey=

# --- Runtime ---
# The session cookie is Secure by default; over plain HTTP (local, http://localhost:8080) it would be dropped, so
# disable Secure locally. In the cloud (HTTPS) set this to true.
Session__Secure=false
# Enables the Wolverine outbox setup + the idempotent demo-document seed at API startup.
Wolverine__DurabilityEnabled=true
